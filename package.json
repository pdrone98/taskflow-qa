{
  "name": "taskflow-qa",
  "version": "1.0.0",
  "description": "Projeto de portfólio QA — automação de testes com Cypress, BDD e validação SQL",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:headed": "cypress run --headed",
    "cy:report": "cypress run --reporter mochawesome",
    "db:setup": "node setup-db.js"
  },
  "overrides": {
    "serialize-javascript": "^6.0.2",
    "diff": "^5.2.0"
  },
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^24.0.1",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
    "better-sqlite3": "^12.9.0",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2"
  }
}
